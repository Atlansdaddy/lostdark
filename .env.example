# Copy this file to `.env.local` and fill in the real values there.
# `.env.local` is gitignored; this example (no secrets) is committed as documentation.

# Meshy 3D asset generation API key — https://www.meshy.ai/api
# Used only by offline asset-generation scripts, NEVER shipped to the browser
# bundle (do not expose it with a VITE_ prefix — that would leak it to every
# visitor's devtools).
MESHY_API_KEY=
