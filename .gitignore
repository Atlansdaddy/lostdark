# Dependencies
node_modules/

# Build output
dist/
build/
*.local

# Secrets / API keys — NEVER commit. Real values live in .env.local (untracked);
# .env.example documents the variable names without the values.
.env
.env.*
!.env.example
secrets/

# Meshy original high-res GLB backups (large; recoverable via the task ids in
# meshy_assets/manifest.json, which IS committed). Keep the manifest, skip the blobs.
meshy_assets/originals/

# Vite / dev caches
.vite/
*.tsbuildinfo

# Python (legacy prototype)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/launch.json
!.vscode/extensions.json

# Logs / misc
*.log
npm-debug.log*

# Accidental Windows reserved-name file
nul
